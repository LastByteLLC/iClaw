{
  "manifest_version": 3,
  "name": "iClaw",
  "version": "1.0.0",
  "description": "Connect iClaw AI agent to your browser for page content extraction and web interaction.",
  "browser_specific_settings": {
    "gecko": {
      "id": "hello@last-byte.org",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "iClaw"
  },
  "background": {
    "scripts": ["shared/compat.js", "shared/protocol.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/compat.js", "shared/protocol.js", "content/extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
