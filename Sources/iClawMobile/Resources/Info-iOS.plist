	<string>iClaw accesses your reminders to check and create tasks.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>iClaw uses speech recognition for voice-to-text input.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>processing</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
