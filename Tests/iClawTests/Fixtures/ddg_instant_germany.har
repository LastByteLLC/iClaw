Germany\",\"wiki_order\":\"212\"},{\"data_type\":\"wikidata_aliases\",\"label\":\"Wikidata aliases\",\"value\":[\"Germany\",\"Federal Republic of Germany\"],\"wiki_order\":\"213\"}],\"meta\":[{\"data_type\":\"string\",\"label\":\"article_title\",\"value\":\"Germany\"},{\"data_type\":\"string\",\"label\":\"template_name\",\"value\":\"infobox\"}]},\"OfficialDomain\":\"bundesregierung.de\",\"OfficialWebsite\":\"https://www.bundesregierung.de/breg-en\",\"Redirect\":\"\",\"RelatedTopics\":[{\"FirstURL\":\"https://duckduckgo.com/c/Germany\",\"Icon\":{\"Height\":\"\",\"URL\":\"\",\"Width\":\"\"},\"Result\":\"<a href=\\\"https://duckduckgo.com/c/Germany\\\">Germany Category</a>\",\"Text\":\"Germany Category\"},{\"FirstURL\":\"https://duckduckgo.com/Outline_of_Germany\",\"Icon\":{\"Height\":\"\",\"URL\":\"\",\"Width\":\"\"},\"Result\":\"<a href=\\\"https://duckduckgo.com/Outline_of_Germany\\\">Outline of Germany</a> - The following outline is provided as an overview of and topical guide to Germany: Germany \\u2013 federal parliamentary republic in Western-Central Europe consisting of 16 constituent states, which retain limited sovereignty. Its capital and largest city is Berlin.\",\"Text\":\"Outline of Germany - The following outline is provided as an overview of and topical guide to Germany: Germany \\u2013 federal parliamentary republic in Western-Central Europe consisting of 16 constituent states, which retain limited sovereignty. Its capital and largest city is Berlin.\"},{\"FirstURL\":\"https://duckduckgo.com/c/Federal_republics\",\"Icon\":{\"Height\":\"\",\"URL\":\"\",\"Width\":\"\"},\"Result\":\"<a href=\\\"https://duckduckgo.com/c/Federal_republics\\\">Federal republics</a>\",\"Text\":\"Federal republics\"},{\"FirstURL\":\"https://duckduckgo.com/c/Member_states_of_NATO\",\"Icon\":{\"Height\":\"\",\"URL\":\"\",\"Width\":\"\"},\"Result\":\"<a href=\\\"https://duckduckgo.com/c/Member_states_of_NATO\\\">Member states of NATO</a>\",\"Text\":\"Member states of NATO\"},{\"F